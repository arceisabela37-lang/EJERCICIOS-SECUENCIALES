PROCESO CALIFICACION_FINAL
ESCRIBIR "DIGITE LA NOTA 1"
LEER NOTA1
ESCRIBIR "DIGITE LA NOTA 2"
LEER NOTA2
ESCRIBIR "DIGITE LA NOTA 3"
LEER NOTA3
PROMEDIO = (NOTA1 + NOTA2 + NOTA3) / 3
ESCRIBIR "DIGITE LA NOTA DEL EXAMEN FINAL"
LEER EXAMEN
ESCRIBIR "DIGITE LA NOTA DEL TRABAJO FINAL"
LEER TRABAJO
PARCIALES = PROMEDIO * 0.55
EXAMEN_FINAL = EXAMEN * 0.30
TRABAJO_FINAL = TRABAJO * 0.15
NOTA_FINAL = PARCIALES + EXAMEN_FINAL + TRABAJO_FINAL
ESCRIBIR "CALIFICACION FINAL: ", NOTA_FINAL

FINPROCESO
