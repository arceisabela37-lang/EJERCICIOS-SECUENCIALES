PROCESO ALCANZAR_VEHICULO
ESCRIBIR "DIGITE LA DISTANCIA ENTRE LOS VEHICULOS (KM)"
LEER D
ESCRIBIR "DIGITE LA VELOCIDAD DEL VEHICULO 1 (KM/H)"
LEER V1
ESCRIBIR "DIGITE LA VELOCIDAD DEL VEHICULO 2 (KM/H)"
LEER V2
TIEMPO = D / (V1 - V2)
TIEMPO_MIN = TIEMPO * 60
ESCRIBIR "EL TIEMPO PARA ALCANZARLO ES ", TIEMPO_MIN, " MINUTOS "
FINPROCESO
