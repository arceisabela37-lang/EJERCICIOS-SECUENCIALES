//PROGRAMA PARA CALCULAR EL AREA Y EL PERIMETRO DE UN RECTANGULO DADA SU BASE Y SU ALTURA//
PROCESO RECTANGULO
ESCRIBIR "DIGITE LA BASE"
LEER BASE
ESCRIBIR "DIGITE LA ALTURA"
LEER ALTURA
AREA = BASE * ALTURA
PERIMETRO = 2 * (BASE + ALTURA)
ESCRIBIR " EL AREA ES ", AREA
ESCRIBIR " EL PERIMETRO ES ", PERIMETRO
FINPROCESO
