PROCESO HORA_LLEGADA
ESCRIBIR "DIGITE LAS HORAS DE SALIDA"
LEER HH
ESCRIBIR "DIGITE LOS MINUTOS DE SALIDA"
LEER MM
ESCRIBIR "DIGITE LOS SEGUNDOS DE SALIDA"
LEER SS
ESCRIBIR "DIGITE EL TIEMPO DE VIAJE EN SEGUNDOS"
LEER T
TOTAL_SEG = HH*3600 + MM*60 + SS
LLEGADA = TOTAL_SEG + T
HORAS = TRUNC(LLEGADA / 3600)
MINUTOS = TRUNC ((LLEGADA MOD 3600) / 60)
SEGUNEDOS = LLEGADA MOD 60
ESCRIBIR "HORA DE LLEGADA: ", HORAS, ":", MINUTOS, ":", SEGUNDOS
FINPROCESO
