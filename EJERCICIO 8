PROCESO SUELDO_VENDEDOR
ESCRIBIR "DIGITE EL SUELDO BASE"
LEER SUELDO_BASE
ESCRIBIR "DIGITE EL VALOR DE LA VENTA 1"
LEER VENTA1
ESCRIBIR "DIGITE EL VALOR DE LA VENTA 2"
LEER VENTA2
ESCRIBIR "DIGITE EL VALOR DE LA VENTA 3"
LEER VENTA3
COMISION1 = VENTA1 * 0.10
COMISION2 = VENTA2 * 0.10
COMISION3 = VENTA3 * 0.10
TOTAL_COMISION = COMISION1 + COMISION2 + COMISION3
TOTAL_MES = SUELDO_BASE + TOTAL_COMISION
ESCRIBIR "COMISION TOTAL: ", TOTAL_COMISION 
ESCRIBIR "SUELDO TOTAL DEL MES: ", TOTAL_MES

FINPROCESO
